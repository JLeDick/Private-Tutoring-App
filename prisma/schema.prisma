generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TUTOR
}

enum AssessmentType {
  PLACEMENT
  ASSIGNMENT
  QUIZ
  UNIT_TEST
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  displayName           String?
  passwordHash          String
  role                  Role
  startingGedPercent    Int       @default(0)
  currentGedPercent     Int       @default(0)
  placementCompletedAt  DateTime?
  recommendedCourseId   String?
  recommendedCoreIdeaId String?
  lastVisitedCourseId   String?
  lastVisitedCoreIdeaId String?

  recommendedCourse   Course?   @relation("RecCourse", fields: [recommendedCourseId], references: [id], onDelete: SetNull)
  recommendedCoreIdea CoreIdea? @relation("RecCore", fields: [recommendedCoreIdeaId], references: [id], onDelete: SetNull)
  lastVisitedCourse     Course?   @relation("LastCourse", fields: [lastVisitedCourseId], references: [id], onDelete: SetNull)
  lastVisitedCoreIdea   CoreIdea? @relation("LastCore", fields: [lastVisitedCoreIdeaId], references: [id], onDelete: SetNull)

  attempts Attempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id        String @id @default(cuid())
  slug      String @unique
  title     String
  sortOrder Int    @default(0)

  coreIdeas   CoreIdea[]
  assessments Assessment[]

  recUsers  User[] @relation("RecCourse")
  lastUsers User[] @relation("LastCourse")
}

model CoreIdea {
  id          String  @id @default(cuid())
  courseId    String
  course      Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  description String?
  sortOrder   Int     @default(0)

  assessments Assessment[]

  recUsers  User[] @relation("RecCore")
  lastUsers User[] @relation("LastCore")

  @@unique([courseId, slug])
}

model Assessment {
  id             String          @id @default(cuid())
  type           AssessmentType
  title          String
  sortOrder      Int             @default(0)
  progressWeight Int             @default(1)

  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  coreIdeaId String?
  coreIdea   CoreIdea? @relation(fields: [coreIdeaId], references: [id], onDelete: Cascade)

  questions Question[]
  attempts  Attempt[]

  @@index([courseId])
  @@index([coreIdeaId])
  @@index([type])
}

model Question {
  id           String       @id @default(cuid())
  assessmentId String
  assessment   Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  sortOrder    Int          @default(0)
  type         QuestionType
  prompt       String
  choicesJson  String? // JSON string array for MC
  correctIndex Int? // MC: 0-based
  points       Int          @default(1)

  answers Answer[]

  @@index([assessmentId])
}

model Attempt {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentId     String
  assessment       Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  startedAt        DateTime  @default(now())
  submittedAt      DateTime?
  durationSeconds  Int?
  earnedPoints     Int?
  maxPoints        Int?
  fullyGraded      Boolean   @default(false)

  answers          Answer[]
  integrityEvents  IntegrityEvent[]

  @@index([userId, assessmentId])
  @@index([userId, submittedAt])
}

model Answer {
  id           String   @id @default(cuid())
  attemptId    String
  attempt      Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  textValue    String?
  selectedIndex Int?
  pointsAwarded Int?
  tutorComment String?

  @@unique([attemptId, questionId])
}

model IntegrityEvent {
  id              String   @id @default(cuid())
  attemptId       String
  attempt         Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId      String?
  eventType       String
  clientTimestamp DateTime?
  pastedLength    Int?
  createdAt       DateTime @default(now())

  @@index([attemptId])
}
