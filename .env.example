# Copy to `.env` for local development (never commit real secrets).

# No password: omit `:password` before `@` (user is `postgres`).
DATABASE_URL="postgresql://postgres@localhost:5432/ged_tutoring?schema=public"

# Required for sign-in cookies. Use a long random string; changing it signs everyone out.
SESSION_SECRET="dev-only-change-to-a-long-random-string-in-production"
